# 生产环境本地配置 - 复制此文件为 .env.production.local 并填写实际值
# This file shows how to configure production environment for your server
# Copy this to .env.production.local and fill in your actual server details

# Replace with your actual production server IP or domain
# 替换为你的实际生产服务器 IP 或域名
VITE_API_BASE_URL=http://your-server-ip:9527
VITE_WS_BASE_URL=ws://your-server-ip:9527
VITE_APP_NAME=RealTime Chat
VITE_APP_VERSION=1.0.0

# Examples / 示例:
# VITE_API_BASE_URL=http://218.28.159.8:8080
# VITE_WS_BASE_URL=ws://218.28.159.8:9527
# Or with domain name:
# VITE_API_BASE_URL=http://chat.example.com:8080
# VITE_WS_BASE_URL=ws://chat.example.com:9527
